# Google Tag Manager Container ID
# Get your container ID at: https://tagmanager.google.com/
VITE_GTM_CONTAINER_ID=GTM-XXXXXXX

# Beehiiv Newsletter Embed URL
# Get your embed URL at: https://app.beehiiv.com/ > Audience > Subscribe forms
VITE_BEEHIIV_EMBED_URL=

# Supabase — email signup backend (card hidden when missing)
# Get these from: https://supabase.com/dashboard > Project Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side Supabase — cron + API routes (NOT prefixed with VITE_)
# Same project URL, but use the service role key for writes
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cron job authentication — any random string, must match cron-job.org config
CRON_SECRET=
